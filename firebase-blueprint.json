{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and authorization data",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "status": { "type": "string", "enum": ["authorized", "pending"] }
      },
      "required": ["email", "role", "status"]
    },
    "Stat": {
      "title": "Stat",
      "description": "Dashboard statistics",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "order": { "type": "integer" },
        "isDynamic": { "type": "boolean" },
        "dynamicKey": { "type": "string" }
      }
    },
    "Request": {
      "title": "Request",
      "description": "Data request from users",
      "type": "object",
      "properties": {
        "requesterName": { "type": "string" },
        "unit": { "type": "string" },
        "contact": { "type": "string" },
        "dataType": { "type": "string" },
        "dataDescription": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "isPublic": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/stats/{statId}": {
      "schema": "Stat",
      "description": "Dashboard stats"
    },
    "/requests/{requestId}": {
      "schema": "Request",
      "description": "Data requests"
    },
    "/documents/{docId}": {
      "schema": { "$ref": "#/entities/Document" },
      "description": "Uploaded documents"
    },
    "/archives/{id}": {
      "schema": { "$ref": "#/entities/Document" },
      "description": "Archived files"
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Staff tasks"
    },
    "/events/{id}": {
      "schema": { "$ref": "#/entities/Event" },
      "description": "Calendar events"
    },
    "/announcements/{id}": {
      "schema": { "$ref": "#/entities/Announcement" },
      "description": "News and updates"
    }
  }
}
