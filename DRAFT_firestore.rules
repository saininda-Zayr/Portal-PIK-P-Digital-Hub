rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helpers
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "saininda@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isAuthorized() {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'authorized')
      );
    }

    // ===============================================================
    // Collection match blocks
    // ===============================================================

    // --- Users ---
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'lastLogin', 'role']) &&
             data.displayName is string && data.displayName.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['admin', 'staff'] &&
             (data.keys().size() == 4 || (data.keys().size() == 5 && data.status in ['authorized', 'pending']) || (data.keys().size() == 5 && data.photoURL is string));
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin(); // Admin can see all users
      
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && 
                       isValidUser(incoming()) &&
                       incoming().role == 'staff' && 
                       (!('status' in incoming()) || incoming().status == 'pending') &&
                       incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && isValidId(userId) && (
        (isAdmin() && isValidUser(incoming())) ||
        (request.auth.uid == userId && 
         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin']) &&
         incoming().displayName is string && incoming().displayName.size() <= 200)
      );
      
      allow delete: if isAdmin() && isValidId(userId);
    }

    // --- Stats ---
    function isValidStat(data) {
      return data.keys().hasAll(['label', 'value', 'icon', 'color', 'order']) &&
             data.label is string && data.label.size() <= 100 &&
             data.value is string && data.value.size() <= 100;
    }

    match /stats/{statId} {
      allow list, get: if isAuthorized();
      allow create, update: if isAdmin() && isValidStat(incoming());
      allow delete: if isAdmin();
    }

    // --- Requests ---
    function isValidRequest(data) {
      return data.keys().hasAll(['requesterName', 'unit', 'dataType', 'reason', 'status', 'createdAt']) &&
             data.requesterName is string && data.requesterName.size() <= 200 &&
             data.status in ['pending', 'processing', 'completed'];
    }

    match /requests/{requestId} {
      allow list: if isAdmin();
      allow get: if isValidId(requestId) && (isAdmin() || (isSignedIn() && existing().uid == request.auth.uid));
      
      allow create: if isValidId(requestId) && isValidRequest(incoming()) && 
                       (!('uid' in incoming()) || incoming().uid == request.auth.uid);
      
      allow update: if isAdmin() && isValidId(requestId) && isValidRequest(incoming()) &&
                       incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin() && isValidId(requestId);
    }

    // --- Documents ---
    function isValidDocument(data) {
      return data.keys().hasAll(['name', 'category', 'createdAt']) &&
             data.name is string && data.name.size() <= 500 &&
             data.category is string && data.category.size() <= 100;
    }

    match /documents/{docId} {
      allow list, get: if isAuthorized();
      allow create: if isAuthorized() && isValidDocument(incoming()) && 
                       incoming().uploadedBy == request.auth.uid;
      allow update: if (isAdmin() || (isAuthorized() && existing().uploadedBy == request.auth.uid)) && 
                       isValidDocument(incoming());
      allow delete: if isAdmin();
    }

    // --- Archives ---
    function isValidArchive(data) {
      return data.keys().hasAll(['name', 'category', 'archiveType', 'createdAt']) &&
             data.name is string && data.name.size() <= 500;
    }

    match /archives/{archiveId} {
      allow list, get: if isAuthorized();
      allow create: if isAuthorized() && isValidArchive(incoming());
      allow update: if isAdmin() && isValidArchive(incoming());
      allow delete: if isAdmin();
    }

    // --- Tasks ---
    function isValidTask(data) {
      return data.keys().hasAll(['task', 'status', 'priority', 'createdAt']) &&
             data.task is string && data.task.size() <= 1000;
    }

    match /tasks/{taskId} {
      allow list, get: if isAuthorized();
      allow create, update: if isAuthorized() && isValidTask(incoming());
      allow delete: if isAdmin();
    }

    // --- Events ---
    match /events/{eventId} {
      allow list, get: if isAuthorized();
      allow write: if isAdmin();
    }

    // --- Announcements ---
    match /announcements/{announcementId} {
      allow list, get: if isAuthorized();
      allow write: if isAdmin();
    }
  }
}
